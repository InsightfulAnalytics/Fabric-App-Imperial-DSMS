{
  "name": "2025 Projects",
  "textClasses": {
    "label": {
      "fontFace": "Arial",
      "fontSize": 11
    },
    "callout": {
      "fontSize": 18,
      "fontFace": "Arial"
    },
    "header": {
      "fontFace": "Arial"
    },
    "title": {
      "fontFace": "Arial",
      "fontSize": 12,
      "color": "#000000"
    }
  },
  "dataColors": [
    "#0F3A57",
    "#3498DB",
    "#63B0E3",
    "#2280BF",
    "#185D8B",
    "#97CAED",
    "#3498DB",
    "#CBE5F6"
  ],
  "visualStyles": {
    "*": {
      "*": {
        "border": [
          {
            "color": {
              "solid": {
                "color": "#B3B3B3"
              }
            },
            "show": true,
            "radius": 7
          }
        ],
        "outspacePane": [
          {
            "headerSize": 10,
            "titleSize": 10,
            "checkboxAndApplyColor": {
              "solid": {
                "color": "#2280BF"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "textSize": 10
          },
          {
            "$id": "Available",
            "textSize": 10
          }
        ],
        "visualTooltip": [
          {
            "themedBackground": {
              "solid": {
                "color": "#EEF6FC"
              }
            }
          }
        ],
        "visualHeaderTooltip": [
          {
            "themedBackground": {
              "solid": {
                "color": "#EEF6FC"
              }
            }
          }
        ]
      }
    }
  },
  "bad": "#BA4956",
  "neutral": "#0F3A57",
  "good": "#3498DB",
  "center": "#0F3A57",
  "maximum": "#3498DB"
}