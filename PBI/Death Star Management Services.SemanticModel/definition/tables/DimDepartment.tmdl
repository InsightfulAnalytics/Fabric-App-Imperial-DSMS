table DimDepartment
	lineageTag: a1000002-0000-0000-0000-000000000001

	column DepartmentKey
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: a1000002-0000-0000-0000-000000000002
		summarizeBy: none
		sourceColumn: DepartmentKey

		annotation SummarizationSetBy = Automatic

	column Department
		dataType: string
		lineageTag: a1000002-0000-0000-0000-000000000003
		summarizeBy: none
		sourceColumn: Department

		annotation SummarizationSetBy = Automatic

	column DivisionGroup
		dataType: string
		lineageTag: a1000002-0000-0000-0000-000000000004
		summarizeBy: none
		sourceColumn: DivisionGroup

		annotation SummarizationSetBy = Automatic

	column CommandingOfficer
		dataType: string
		lineageTag: a1000002-0000-0000-0000-000000000005
		summarizeBy: none
		sourceColumn: CommandingOfficer

		annotation SummarizationSetBy = Automatic

	column Sector
		dataType: string
		lineageTag: a1000002-0000-0000-0000-000000000006
		summarizeBy: none
