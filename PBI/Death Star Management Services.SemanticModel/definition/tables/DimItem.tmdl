		isHidden
		formatString: 0
		lineageTag: a1000004-0000-0000-0000-000000000002
		summarizeBy: none
		sourceColumn: ItemKey

		annotation SummarizationSetBy = Automatic

	column Item
		dataType: string
		lineageTag: a1000004-0000-0000-0000-000000000003
		summarizeBy: none
		sourceColumn: Item

