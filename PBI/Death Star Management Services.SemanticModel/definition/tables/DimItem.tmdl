	partition DimItem = m
		mode: import
		queryGroup: Model
		source =
				let
				    Source = Csv.Document(File.Contents("b:\VS Code Files\PBI Project\Star Wars\data\DimItem.csv"), [Delimiter=",", Columns=8, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    PromoteHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				    ChangeTypes = Table.TransformColumnTypes(PromoteHeaders, {
				        {"ItemKey", Int64.Type},
				        {"Item", type text},
				        {"ItemCategory", type text},
				        {"UnitOfMeasure", type text},
				        {"UnitCostCredits", Int64.Type},
				        {"Perishable", type text},
				        {"LeadTimeDays", Int64.Type},
				        {"PreferredVendorKey", Int64.Type}
				    })
				in
				    ChangeTypes

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

