{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chrome/**",
              "components/data/**",
              "components/forms/**",
              "components/foundation/**",
              "ui_kits/fabric-console/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Rajdhani|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Rajdhani, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconTrailing|disabled|block|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconTrailing, disabled, block, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|numeric|width|render|key|ref|className|style|children)$/]",
        "message": "<DataTableColumn> doesn't accept that prop. Declared props: key, label, align, numeric, width, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<DataTableColumn> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeltaIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|format|invert|size|showArrow|style|key|ref|className|style|children)$/]",
        "message": "<DeltaIndicator> doesn't accept that prop. Declared props: value, format, invert, size, showArrow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeltaIndicator'] > JSXAttribute[name.name='format'] > Literal[value!=/^(?:percent|number|none)$/]",
        "message": "<DeltaIndicator> format must be one of 'percent' | 'number' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeltaIndicator'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<DeltaIndicator> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Gauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|redBelow|warnBelow|label|size|thickness|style|key|ref|className|style|children)$/]",
        "message": "<Gauge> doesn't accept that prop. Declared props: value, redBelow, warnBelow, label, size, thickness, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|style|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|variant|active|disabled|title|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, variant, active, disabled, title, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|solid)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|icon|type|size|disabled|invalid|numeric|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, defaultValue, placeholder, icon, type, size, disabled, invalid, numeric, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Input> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|deltaLabel|deltaFormat|invertDelta|sparkData|sparkColor|accent|style|key|ref|className|style|children)$/]",
        "message": "<KpiTile> doesn't accept that prop. Declared props: label, value, unit, delta, deltaLabel, deltaFormat, invertDelta, sparkData, sparkColor, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiTile'] > JSXAttribute[name.name='deltaFormat'] > Literal[value!=/^(?:percent|number|none)$/]",
        "message": "<KpiTile> deltaFormat must be one of 'percent' | 'number' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|actions|padded|children|style|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, eyebrow, actions, padded, children, style, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|actions|size|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: eyebrow, title, actions, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<SectionHeader> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<SidebarItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlicerOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SlicerOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|width|height|color|fillOpacity|strokeWidth|showDots|showEndLabel|endLabel|zero|style|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, width, height, color, fillOpacity, strokeWidth, showDots, showEndLabel, endLabel, zero, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|status|variant|dot|size|style|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: children, status, variant, dot, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:positive|negative|warning|info|neutral)$/]",
        "message": "<StatusPill> status must be one of 'positive' | 'negative' | 'warning' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<StatusPill> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<StatusPill> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|disabled|label|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, disabled, label, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|breadcrumb|children|onToggleRail|style|key|ref|className|style|children)$/]",
        "message": "<TopBar> doesn't accept that prop. Declared props: title, breadcrumb, children, onToggleRail, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
